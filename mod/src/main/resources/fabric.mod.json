{
	"schemaVersion": 1,
	"id": "charaformact",
	"version": "${version}",
	"name": "CharaFormAct",
	"description": "The engine that powers the character-form-action framework under the hood. Separate from the API to keep things clean.",
	"authors": [
		"Floral qua Floral"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/mario-qua-mario",
		"sources": "https://github.com/floral-qua-floral/marioQuaMario",
		"issues": "https://github.com/floral-qua-floral/marioQuaMario/issues"
	},
	"license": "GPL-3.0-only",
	"icon": "assets/charaformact/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.fqf.charaformact.CharaFormAct"
		],
		"client": [
			"com.fqf.charaformact.CharaFormActClient"
		],
		"fabric-datagen": [
			"com.fqf.charaformact.CharaFormActDataGenerator"
		],

		"modmenu": [
			"com.fqf.charaformact.util.ModMenuIntegration"
		],

		"cfa-common-appearances": [
			"com.fqf.charaformact.appearance.temp.TemplateCommonAppearance",
			"com.fqf.charaformact.appearance.temp.WonkyCommonAppearance",
			"com.fqf.charaformact.appearance.temp.SmallCommonAppearance"
		],

		"cfa-client-appearances": [
			"com.fqf.charaformact.appearance.temp.TemplateClientAppearance",
			"com.fqf.charaformact.appearance.temp.WonkyClientAppearance",
			"com.fqf.charaformact.appearance.temp.SmallClientAppearance"
		]
	},
	"mixins": [
		"charaformact.mixins.json",
		{
			"config": "charaformact.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.9",
		"minecraft": "~1.21",
		"java": ">=21",
		"fabric-api": "*",
		"cloth-config": "*",
		"charaformact_api": "*"
	},
	"suggests": {

	},
	"custom": {
		"loom:injected_interfaces": {
			"net/minecraft/class_1657": ["com/fqf/charaformact/cfadata/injections/AdvCfaDataHolder"],
			"net/minecraft/class_3222": ["com/fqf/charaformact/cfadata/injections/AdvCfaServerDataHolder"],

			"net/minecraft/class_742": ["com/fqf/charaformact/cfadata/injections/AdvCfaAbstractClientDataHolder"],
			"net/minecraft/class_746": ["com/fqf/charaformact/cfadata/injections/AdvCfaMainClientDataHolder"],
			"net/minecraft/class_745": ["com/fqf/charaformact/cfadata/injections/AdvCfaOtherClientDataHolder"]
		}
	},

	"accessWidener" : "charaformact.accesswidener"
}