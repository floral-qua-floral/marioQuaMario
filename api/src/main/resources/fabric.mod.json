	},
	"license": "CC0-1.0",
	"icon": "assets/qua_mario/icon.png",
	"environment": "*",
	"entrypoints": {
	},
	"mixins": [
		"qua_mario_api.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.16.7",
		"minecraft": "~1.21",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"another-mod": "*"
	},

	"custom": {
