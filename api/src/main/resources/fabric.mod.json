{
	"schemaVersion": 1,
	"id": "charapoweract_api",
	"version": "${version}",
	"name": "CharaPowerAct API",
	"description": "Library mod that contains all the little bits necessary to make a mod that uses the character-power-action framework.",
	"authors": [
		"Floral qua Floral"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/mario-qua-mario",
		"sources": "https://github.com/floral-qua-floral/marioQuaMario",
		"issues": "https://github.com/floral-qua-floral/marioQuaMario/issues"
	},
	"license": "GPL-3.0-only",
	"icon": "assets/charapoweract_api/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.fqf.charapoweract_api.CharaPowerActAPI"
		],
		"client": [
			"com.fqf.charapoweract_api.CharaPowerActAPIClient"
		],
		"fabric-datagen": [
			"com.fqf.charapoweract_api.CharaPowerActAPIDataGenerator"
		]
	},
	"mixins": [
		"charapoweract_api.mixins.json",
		{
			"config": "charapoweract_api.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.9",
		"minecraft": "~1.21",
		"java": ">=21",
		"fabric-api": "*",
		"charapoweract": "*"
	},
	"suggests": {

	},

	"custom": {
		"loom:injected_interfaces": {
			"net/minecraft/class_1657": ["com/fqf/charapoweract_api/cpadata/injections/ICPADataHolder"],
			"net/minecraft/class_3222": [
				"com/fqf/charapoweract_api/cpadata/injections/ICPAAuthoritativeDataHolder",
				"com/fqf/charapoweract_api/cpadata/injections/ICPATravelDataHolder"
			],

			"net/minecraft/class_742": ["com/fqf/charapoweract_api/cpadata/injections/ICPAClientDataHolder"],
			"net/minecraft/class_746": [
				"com/fqf/charapoweract_api/cpadata/injections/ICPAClientDataHolder",
				"com/fqf/charapoweract_api/cpadata/injections/ICPATravelDataHolder"
			],
			"net/minecraft/class_745": ["com/fqf/charapoweract_api/cpadata/injections/ICPAClientDataHolder"]
		}
	}
}