{
	"schemaVersion": 1,
	"id": "charaformact_api",
	"version": "${version}",
	"name": "CharaFormAct API",
	"description": "Library mod that contains all the little bits necessary to make a mod that uses the character-form-action framework.",
	"authors": [
		"Floral qua Floral"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/mario-qua-mario",
		"sources": "https://github.com/floral-qua-floral/marioQuaMario",
		"issues": "https://github.com/floral-qua-floral/marioQuaMario/issues"
	},
	"license": "GPL-3.0-only",
	"icon": "assets/charaformact_api/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.fqf.charaformact_api.CharaFormActAPI"
		],
		"client": [
			"com.fqf.charaformact_api.CharaFormActAPIClient"
		],
		"fabric-datagen": [
			"com.fqf.charaformact_api.CharaFormActAPIDataGenerator"
		]
	},
	"mixins": [
		"charaformact_api.mixins.json",
		{
			"config": "charaformact_api.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.16.9",
		"minecraft": "~1.21",
		"java": ">=21",
		"fabric-api": "*",
		"charaformact": "*"
	},
	"suggests": {

	},

	"custom": {
		"loom:injected_interfaces": {
			"net/minecraft/class_1657": ["com/fqf/charaformact_api/cfadata/injections/CfaDataHolder"],
			"net/minecraft/class_3222": ["com/fqf/charaformact_api/cfadata/injections/CfaAuthoritativeDataHolder"],

			"net/minecraft/class_742": ["com/fqf/charaformact_api/cfadata/injections/CfaClientDataHolder"],
			"net/minecraft/class_746": ["com/fqf/charaformact_api/cfadata/injections/CfaClientDataHolder"],
			"net/minecraft/class_745": ["com/fqf/charaformact_api/cfadata/injections/CfaClientDataHolder"]
		}
	}
}